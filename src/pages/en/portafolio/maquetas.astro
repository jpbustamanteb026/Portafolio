---
import BtnBackPortafolio from "../../../components/BtnBackPortafolio.astro";
import Layout from "../../../layouts/Layout.astro";
import CardPortfolioSoftware from "../../../components/CardPortfolioSoftware.astro";
import "../../../styles/portafolio.css";

const titulo = "MOCKUPS";

const stack = [
  {
    color: "#358541",
    name: "CAMPUS MAP",
    textoBtnRepositorio: "Design board",
    urlRepositorio:
      "https://www.figma.com/design/6WozWQHFniG5JLHlEhlXBD/CAMPUS-MAP?node-id=0-1&t=YwQBPJRnH3bbrvVD-1",
    textoBtnDemo: "Prototype",
    urlDemo:
      "https://www.figma.com/proto/6WozWQHFniG5JLHlEhlXBD/CAMPUS-MAP?node-id=243-2420&p=f&t=2QWzFXvHk4Z1Itiw-1&scaling=scale-down&content-scaling=fixed&page-id=0%3A1&starting-point-node-id=1%3A93",
    description:
      "Initial prototype of a GPS system for the Alliance of Bioversity and CIAT Palmira campus. The intention is to help visitors navigate the campus in real time.",
  },
  {
    color: "#e76489",
    name: "PORTFOLIO",
    textoBtnRepositorio: "Design board",
    urlRepositorio:
      "https://www.figma.com/design/vmCppvK0BeaJENdfdIAiZl/Portafolio?node-id=0-1&t=YwQBPJRnH3bbrvVD-1",
    textoBtnDemo: "Prototype",
    urlDemo:
      "https://www.figma.com/proto/vmCppvK0BeaJENdfdIAiZl/Portafolio?node-id=1-2&p=f&t=yg5hFtMyBKWX3r28-1&scaling=scale-down&content-scaling=fixed&page-id=0%3A1&starting-point-node-id=1%3A93",
    description:
      "Portfolio mockup. The goal is to reflect my personality and my love for Japanese culture; the choice of pink is inspired by cherry blossoms, a tree common in both Japan and my hometown, Cali.",
  },
  {
    color: "#EA6113",
    name: "ValleO2",
    textoBtnRepositorio: "Design board",
    urlRepositorio:
      "https://www.figma.com/design/Ul1pW4bWdhKTxvU5RdBXzB/Dashboard-Clim%C3%A1tico?node-id=1-2&t=oPInJOl0tEIk1tEK-1",
    textoBtnDemo: "Prototype",
    urlDemo:
      "https://www.figma.com/proto/Ul1pW4bWdhKTxvU5RdBXzB/Dashboard-Clim%C3%A1tico?node-id=311-2055&p=f&t=KtpIb0uRTzimMpZ9-1&scaling=contain&content-scaling=fixed&page-id=1%3A2&starting-point-node-id=311%3A2055&show-proto-sidebar=1",
    description:
      "Climate Panel of Cali, Colombia. The idea is to develop a tool to check the weather, review historical data from previous days, and receive recommendations using AI.",
  },
];
---

<Layout>
  <div class="cuerpo">
    <BtnBackPortafolio titulo={titulo} />
    <CardPortfolioSoftware items={stack} />
  </div>
</Layout>
