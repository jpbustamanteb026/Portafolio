---
import BtnBackPortafolio from "../../../components/BtnBackPortafolio.astro";
import Layout from "../../../layouts/Layout.astro";
import CardPortfolioSoftware from "../../../components/CardPortfolioSoftware.astro";
import "../../../styles/portafolio.css";

const titulo = "DEVELOPMENT";

const stack = [
  {
    color: "#358541",
    name: "CAMPUS MAP",
    textoBtnRepositorio: "Repository",
    urlRepositorio:
      "https://github.com/AllianceBioversityCIAT/alliance-campusmap",
    textoBtnDemo: "Demo",
    urlDemo: "https://d3e9f51uy3dvsk.cloudfront.net/home",
    description:
      "Interactive campus navigation app for Alliance Bioversity International & CIAT. Built with Angular and NestJS, deployed on AWS (CloudFront, S3, Lambda) with Jenkins CI/CD. Features a 3D campus view, georeferenced road layout, building rendering, and indoor navigation. Developed during my frontend internship.",
  },
  {
    color: "#849584",
    name: "Endansys",
    textoBtnRepositorio: "Repositorio",
    urlRepositorio: "https://github.com/NataliaGiraldoA/Endansys",
    description:
      "An artificial intelligence-based tool for identifying and classifying endangered species in Colombia. Developed using a ResNet50 convolutional neural network and transfer learning, it achieves 88.75% accuracy and an AUC of 0.998. From an image, the system classifies the species, determines its extinction risk, and displays its habitat on a map. Published as an academic article at San Buenaventura University in Cali.",
  },
  {
    color: "#7A61B5",
    name: "GeoClusters",
    textoBtnRepositorio: "Repositorio",
    urlRepositorio: "https://github.com/jpbustamanteb026/GeoClusters",
    description:
      "Unsupervised ML tool for classifying seismic risk zones across South America. Applied K-Means clustering over 52,000+ real USGS earthquake events, achieving a Silhouette Score of 0.52. Results are displayed on an interactive Folium map with 4 risk levels: Low, Medium, High and Very High. Published as an academic paper at Universidad San Buenaventura Cali.",
  },
  {
    color: "#e76489",
    name: "PORTFOLIO",
    textoBtnRepositorio: "Repository",
    urlRepositorio: "https://github.com/jpbustamanteb026/Portafolio",
    textoBtnDemo: "Demo",
    urlDemo: "https://juanpablobustamante.com/",
    description:
      "Portfolio developed entirely by me, without templates. The goal is to showcase my frontend development skills, emphasizing user experience and making it as intuitive as possible, always adhering to the principles of digital ergonomics and, most importantly, the end user. This also includes optimizing and ensuring the website's smooth performance.",
  },
];
---

<Layout>
  <div class="cuerpo">
    <BtnBackPortafolio titulo={titulo} />
    <CardPortfolioSoftware items={stack} />
  </div>
</Layout>
