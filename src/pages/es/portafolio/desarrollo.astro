---
import BtnBackPortafolio from "../../../components/BtnBackPortafolio.astro";
import Layout from "../../../layouts/Layout.astro";
import CardPortfolioSoftware from "../../../components/CardPortfolioSoftware.astro";
import "../../../styles/portafolio.css";

const titulo = "DESARROLLO";

const stack = [
  {
    color: "#358541",
    name: "CAMPUS MAP",
    textoBtnRepositorio: "Repositorio",
    urlRepositorio:
      "https://github.com/AllianceBioversityCIAT/alliance-campusmap",
    textoBtnDemo: "Demo",
    urlDemo: "https://d3e9f51uy3dvsk.cloudfront.net/home",
    description:
      "Aplicación interactiva de navegación por el campus para Alliance Bioversity International and CIAT. Desarrollada con Angular y NestJS, desplegada en AWS (CloudFront, S3, Lambda) con Jenkins CI/CD. Incluye vista 3D del campus, trazado de carreteras georreferenciado, renderizado de edificios y navegación en interiores. Desarrollada durante mis prácticas de desarrollo frontend.",
  },
  {
    color: "#849584",
    name: "Endansys",
    textoBtnRepositorio: "Repositorio",
    urlRepositorio: "https://github.com/NataliaGiraldoA/Endansys",
    description:
      "Herramienta basada en inteligencia artificial para la identificación y clasificación de especies en peligro de extinción en Colombia. Desarrollada con una red neuronal convolucional ResNet50 y aprendizaje por transferencia, alcanza una precisión del 88,75 % y un AUC de 0,998. A partir de una imagen, el sistema clasifica la especie, determina su riesgo de extinción y muestra su hábitat en un mapa. Publicada como artículo académico en la Universidad San Buenaventura Cali.",
  },
  {
    color: "#7A61B5",
    name: "GeoClusters",
    textoBtnRepositorio: "Repositorio",
    urlRepositorio: "https://github.com/jpbustamanteb026/GeoClusters",
    description:
      "Herramienta de aprendizaje automático no supervisado para clasificar zonas de riesgo sísmico en Sudamérica. Se aplicó el algoritmo de agrupamiento K-Means a más de 52.000 eventos sísmicos reales del USGS, obteniendo un índice Silhouette de 0,52. Los resultados se muestran en un mapa interactivo de Folium con cuatro niveles de riesgo: Bajo, Medio, Alto y Muy Alto. Publicado como artículo académico en la Universidad San Buenaventura Cali.",
  },
  {
    color: "#e76489",
    name: "Portafolio",
    textoBtnRepositorio: "Repositorio",
    urlRepositorio: "https://github.com/jpbustamanteb026/Portafolio",
    textoBtnDemo: "Demo",
    urlDemo: "https://juanpablobustamante.com/",
    description:
      "Portafolio desarrollado completamente por mí, sin plantillas. El objetivo es mostrar mis habilidades en desarrollo frontend, destacando la experiencia de usuario, haciendola lo más intuitiva posible, siempre bajo los principios de ergonomía digital y lo más importante, el usuario final. Además de la optimización y fluidez de la página.",
  },
];
---

<Layout>
  <div class="cuerpo">
    <BtnBackPortafolio titulo={titulo} />
    <CardPortfolioSoftware items={stack} />
  </div>
</Layout>
