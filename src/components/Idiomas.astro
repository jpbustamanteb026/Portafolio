---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="categoria">
  <h2 class="titulo-categoria">{t("languages.title")}</h2>
  <dl class="idiomas">
    <div class="idioma">
      <dt>{t("languages.spanish")}</dt>
      <dd>{t("languages.spanishLevel")}</dd>
    </div>
    <div class="idioma">
      <dt>{t("languages.english")}</dt>
      <dd>{t("languages.englishLevel")}</dd>
    </div>
  </dl>
</div>

<style>
  .idiomas {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    align-self: stretch;
    flex-wrap: wrap;
  }

  .idioma {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .idioma dt {
    font-weight: var(--font-weight-bold);
  }

  .idioma dt::after {
    content: " -";
  }

  .idioma dd {
    font-size: var(--lead-font-size-mobile);
    line-height: var(--line-height-140);
    font-weight: var(--font-weight-regular);
  }

  /* Tablet */
  @media screen and (min-width: 768px) {
    .idioma dt {
      font-size: var(--subtitle2-font-size);
    }

    .idioma dd {
      font-size: var(--lead-font-size);
    }

    .idiomas {
      justify-content: center;
      align-items: center;
      gap: 10rem;
      height: 100%;
    }
  }
</style>
