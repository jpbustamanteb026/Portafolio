---
import Cards from "./CardPortfolio.astro";

const baseDir = import.meta.env.BASE_URL;

const getPath = (path: string) => {
  const merged = `${baseDir}/${path}`;
  return merged.replace(/\/+/g, "/");
};

const stack = [
  {
    name: "ANGULAR",
    icon: getPath("icons/angular.svg"),
    url: getPath("portafolio/angular"),
  },
  {
    name: "ASTRO",
    icon: getPath("icons/astro.svg"),
    url: getPath("portafolio/astro"),
  },
  {
    name: "MAQUETAS",
    icon: getPath("icons/figma.svg"),
    url: getPath("portafolio/maquetas"),
  },
  {
    name: "PRÓXIMAMENTE",
    icon: getPath("icons/proximamente.svg"),
    url: getPath("portafolio/proximamente"),
  },
];
---

<div class="cuerpo">
  <h2 class="titulo">PORTAFOLIO</h2>
  <Cards items={stack} />
</div>

<style>
  .cuerpo {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.5rem;
    gap: 1.5rem;
    min-height: calc(100dvh - 5rem);
  }

  .titulo {
    color: var(--color-blanco);
    font-family: var(--titulos);
    font-size: var(--display-font-size-mobile);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-120);
  }

  /* Tablet */
  @media screen and (min-width: 768px) {
    .titulo {
      font-size: var(--display-font-size);
    }
  }
</style>
