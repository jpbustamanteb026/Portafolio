---
const { items } = Astro.props;
---

<section class="skills-list">
  {
    items.map((item: any) => (
      <div class="skill-item">
        <img src={item.icon} alt={item.name} />
        <span>{item.name}</span>
      </div>
    ))
  }
</section>

<style>
  .skills-list {
    display: flex;
    padding-bottom: 1.25rem;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  .skill-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
</style>
