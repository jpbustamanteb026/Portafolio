---
const { items } = Astro.props;
---

<section class="skills-list">
  {
    items.map((item: any) => (
      <div class="skill-item">
        <img src={item.icon} alt={item.name} loading="lazy" />
        <span class="nombre-item">{item.name}</span>
      </div>
    ))
  }
</section>

<style>
  .skills-list {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  .skill-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  /* Tablet */
  @media screen and (min-width: 768px) {
    .skills-list {
      flex-direction: row;
    }
    .nombre-item {
      font-size: var(--subtitle2-font-size);
    }
  }
</style>
