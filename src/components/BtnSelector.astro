---
const { texto, url } = Astro.props;

const { pathname } = Astro.url;

const esIngles = pathname.startsWith("/en/") || pathname.includes("/en/");

const rutaRealPdf = esIngles
  ? "/CV_Juan_Bustamante_EN.pdf"
  : "/CV_Juan_Bustamante_ES.pdf";

const nombreArchivo = esIngles
  ? "CV_Juan_Bustamante_EN.pdf"
  : "CV_Juan_Bustamante_ES.pdf";
---

<a href={rutaRealPdf} download={nombreArchivo} class="boton-hoja-vida"
  >{texto}</a
>

<style>
  .boton-hoja-vida {
    border-radius: 30px;
    border: 2px solid var(--color-blanco);
    display: flex;
    padding: 17px 28px;
    justify-content: center;
    align-items: center;
    color: var(--color-blanco);
    text-align: center;
    text-decoration: none;
    font-family: var(--cuerpo);
    font-size: var(--lead-font-size-mobile);
    font-style: normal;
    line-height: var(--line-height-140);
  }

  .boton-hoja-vida:active {
    color: var(--color-rosa);
    border-color: var(--color-rosa);
  }

  /* Tablet */
  @media screen and (min-width: 768px) {
    .boton-hoja-vida {
      font-size: var(--lead-font-size);
    }
  }

  /* Desktop */
  @media screen and (min-width: 1025px) {
    .boton-hoja-vida:hover {
      border-color: var(--color-rosa);
      color: var(--color-rosa);
      transition:
        border-color 0.3s ease,
        color 0.3s ease;
    }
  }
</style>
