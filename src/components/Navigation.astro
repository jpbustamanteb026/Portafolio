---
import { base } from "astro:config/client";

// Mantiene el color Rosa en la ventana seleccionada
const { pathname } = Astro.url;

const normalize = (path: string) => path.replace(/\/$/, "") || "/";

const currentPath = normalize(pathname);
const basePath = normalize(base || "/");

const sobreMiPath = normalize(`${base}/sobremi`);
const resumePath = normalize(`${base}/resume`);
const portafolioPath = normalize(`${base}/portafolio`);

const isPortafolioActive =
  currentPath === portafolioPath ||
  currentPath.startsWith(`${portafolioPath}/`);
---

<div id="main-menu" class="nav-links">
  <a href={base || "/"} class={currentPath === basePath ? "active" : ""}
    >Inicio</a
  >
  <a
    href={`${base}/sobremi`}
    class={currentPath === sobreMiPath ? "active" : ""}>Sobre mí</a
  >
  <a href={`${base}/resume`} class={currentPath === resumePath ? "active" : ""}
    >Resume</a
  >
  <a href={`${base}/portafolio`} class={isPortafolioActive ? "active" : ""}
    >Portafolio</a
  >
</div>
