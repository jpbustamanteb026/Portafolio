---
const { pathname } = Astro.url;

const siteUrl = Astro.site ? Astro.site.origin : "";
const baseDir = import.meta.env.BASE_URL;

const cleanPath = (path: string) =>
  path.replace(/\/+/g, "/").replace(/\/$/, "") || "/";

const currentPath = cleanPath(pathname);

const basePath = cleanPath(baseDir);
const sobreMiPath = cleanPath(`${baseDir}/sobremi`);
const resumePath = cleanPath(`${baseDir}/resume`);
const portafolioPath = cleanPath(`${baseDir}/portafolio`);

const isPortafolioActive =
  currentPath === portafolioPath ||
  currentPath.startsWith(`${portafolioPath}/`);

const getHref = (path: string) => {
  const merged = `${baseDir}/${path}`;
  const finalized = merged.replace(/\/+/g, "/");
  return finalized.startsWith("/") ? finalized : `/${finalized}`;
};
---

<div id="main-menu" class="nav-links">
  <a href={basePath} class={currentPath === basePath ? "active" : ""}>Inicio</a>
  <a
    href={getHref("sobremi")}
    class={currentPath === sobreMiPath ? "active" : ""}>Sobre mí</a
  >
  <a href={getHref("resume")} class={currentPath === resumePath ? "active" : ""}
    >Resume</a
  >
  <a href={getHref("portafolio")} class={isPortafolioActive ? "active" : ""}
    >Portafolio</a
  >
</div>
