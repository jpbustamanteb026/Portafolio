---
import BtnSelectorPortafolio from "./BtnSelectorPortafolio.astro";
const { items } = Astro.props;
---

<section class="projects">
  {
    items.map((item: any) => (
      <div class="project-card" tabindex="0" style="background-color: none;">
        <div class="project-overlay">
          <div class="project-name">{item.name}</div>
          <div class="project-description">
            <span>{item.description}</span>
          </div>
          <div class="project-buttons">
            <div class="buttons-inner-container">
              <BtnSelectorPortafolio
                texto={item.textoBtnRepositorio}
                url={item.urlRepositorio}
                color={item.color}
              />
              {item.urlDemo ? (
                <BtnSelectorPortafolio
                  texto={item.textoBtnDemo}
                  url={item.urlDemo}
                  color={item.color}
                />
              ) : null}
            </div>
          </div>
        </div>
      </div>
    ))
  }
</section>

<style>
  .projects {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 100%;
    gap: 20px;
    flex-wrap: wrap;
  }

  .project-card {
    width: 100%;
    max-width: 420px;
    border-radius: 2.5rem;
    border: 4px solid var(--color-blanco);
    background-size: cover;
    background-position: top;
    background-repeat: no-repeat;
  }

  .project-overlay {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 40px;
  }

  .project-name {
    font-size: var(--display-font-size-mobile);
    text-align: center;
    font-weight: var(--font-weight-bold);
  }

  .project-description {
    text-align: justify;
    font-size: var(--lead-font-size-mobile);
    display: grid;
    max-height: 4.5em;
    transition: max-height 1s ease;
    overflow: hidden;
    position: relative;
  }

  .project-description::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2em;
    /* Cambia este color al fondo real de tu card */
    background: linear-gradient(transparent, var(--color-negro));
    pointer-events: none;
    transition: opacity 1.5s ease;
  }

  .project-card:hover .project-description::after,
  .project-card:focus .project-description::after {
    opacity: 0;
  }

  .project-description span {
    overflow: hidden;
  }

  .project-card:hover .project-description,
  .project-card:focus .project-description {
    max-height: 500px;
  }

  .project-buttons {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.5s ease;
  }

  .buttons-inner-container {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 20px;
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 2s ease,
      transform 1s ease;
  }

  .project-card:hover .project-buttons,
  .project-card:focus .project-buttons {
    grid-template-rows: 1fr;
  }

  .project-card:hover .buttons-inner-container,
  .project-card:focus .buttons-inner-container {
    opacity: 1;
    transform: translateY(0);
    padding-top: 15px;
  }

  /* Tablet */
  @media screen and (min-width: 768px) {
    .project-name {
      font-size: var(--display-font-size);
    }

    .project-card {
      max-width: 550px;
    }

    .project-description {
      font-size: var(--lead-font-size);
    }

    .buttons-inner-container {
      flex-direction: row;
    }
  }

  @media screen and (min-width: 1025px) {
    .projects {
      flex-direction: row;
    }
  }
</style>
