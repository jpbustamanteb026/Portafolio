---
import HabilidadesStack from "./HabilidadesStack.astro";

const baseDir = import.meta.env.BASE_URL;

const getIconPath = (path: string) => {
  const merged = `${baseDir}/${path}`;
  return merged.replace(/\/+/g, "/");
};

const habilidades = [
  {
    name: "Aprendizaje rápido",
    icon: getIconPath("icons/aprendizaje-rapido.svg"),
  },
  { name: "Trabajo en equipo", icon: getIconPath("icons/trabajo-equipo.svg") },
  { name: "Proactivo", icon: getIconPath("icons/proactivo.svg") },
];
---

<div class="categoria">
  <h2 class="titulo-categoria">Habilidades Personales</h2>
  <HabilidadesStack items={habilidades} />
</div>
