---
import HabilidadesStack from "./HabilidadesStack.astro";

const base = import.meta.env.BASE_URL;

const habilidades = [
  { name: "Aprendizaje rápido", icon: `${base}/icons/aprendizaje-rapido.svg` },
  { name: "Trabajo en equipo", icon: `${base}/icons/trabajo-equipo.svg` },
  { name: "Proactivo", icon: `${base}/icons/proactivo.svg` },
];
---

<div class="categoria">
  <h2 class="titulo-categoria">Habilidades Personales</h2>
  <HabilidadesStack items={habilidades} />
</div>
